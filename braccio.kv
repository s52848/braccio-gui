<BraccioRoot>:
    orientation: "vertical"

    BoxLayout:
        size_hint_y: 0.1

        canvas.before:
            Color:
                rgba: (1, 0.5, 0, 1)
            Rectangle:
                pos: self.pos
                size: self.size

        Button:
            text: "Connect"
            background_color: (0.5, 0.5, 0.5, 1)
            color: (1, 1, 1, 1)
            size_hint_x: 0.4

        Button:
            text: "Disconnect"
            background_color: (0.5, 0.5, 0.5, 1)
            color: (1, 1, 1, 1)
            size_hint_x: 0.4

    ScreenManager:
        id: sm

        Screen:
            name: "Menu"

            BoxLayout:
                orientation: "vertical"

                Button:
                    text: "Mode 1: Test"
                    on_press: sm.current = "Test"

                Button:
                    text: "Mode 2: Manual"
                    on_press: sm.current = "Manual"

                Button:
                    text: "Mode 3: Automatic"
                    on_press: sm.current = "Automatic"

                Button:
                    text: "Exit"

        Screen:
            name: "Test"

            Button:
                text: "Back"
                on_press: sm.current = "Menu"

        Screen:
            name: "Manual"

            BoxLayout:
                orientation: "vertical"

                Label:
                    text: "Base"
                    
                Slider:
                    id: "base"
                    min: 0
                    max: 100
                    value: 50

                Label:
                    text: "Shoulder"
                    
                Slider:
                    id: "shoulder"
                    min: 0
                    max: 100
                    value: 50

                Label:
                    text: "Elbow"
                    
                Slider:
                    id: "elbow"
                    min: 0
                    max: 100
                    value: 50

                Label:
                    text: "Vertical Wrist"
                    
                Slider:
                    id: "vwrist"
                    min: 0
                    max: 100
                    value: 50

                Label:
                    text: "Rotatory Wrist"
                    
                Slider:
                    id: "rwrist"
                    min: 0
                    max: 100
                    value: 50

                Label:
                    text: "Gripper"
                    
                Slider:
                    id: "gripper"
                    min: 0
                    max: 100
                    value: 50

                Button:
                    text: "Back"
                    on_press: sm.current = "Menu"

        Screen:
            name: "Automatic"

            Button:
                text: "Back"
                on_press: sm.current = "Menu"
 